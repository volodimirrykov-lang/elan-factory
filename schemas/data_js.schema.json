{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ELAN Factory — window.ELAN_DATA shape",
  "description": "Контракт между build_data.py и docs/*.html. Если HTML-страница использует поле, оно должно быть здесь.",
  "type": "object",
  "required": ["meta", "months", "agKassa", "cashPositions", "scenarios", "loreal_acquisitions", "valuation"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["entity", "country", "headcount", "ownerShare", "currentValuation", "targetValuation", "targetYears", "brandLaunch", "fxEurUsd", "fxTlEur", "lastUpdate", "sourceSnapshots"],
      "properties": {
        "entity": {"type": "string"},
        "country": {"type": "string"},
        "headcount": {"type": "integer", "minimum": 1},
        "ownerShare": {"type": "number", "minimum": 0, "maximum": 1},
        "currentValuation": {"type": "integer", "minimum": 0},
        "targetValuation": {"type": "integer", "minimum": 0},
        "targetYears": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "brandLaunch": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
        "fxEurUsd": {"type": "number"},
        "fxTlEur": {"type": "number"},
        "lastUpdate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "sourceSnapshots": {"type": "array", "items": {"type": "string"}}
      }
    },
    "months": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["month", "label", "status", "revenue", "cashIn", "cashOut", "cogs", "opex", "totalRevenue", "opProfit", "opMargin", "clients"],
        "properties": {
          "month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "label": {"type": "string"},
          "status": {"type": "string"},
          "note": {"type": "string"},
          "revenue": {"type": "number"},
          "cashIn": {"type": "number"},
          "cashOut": {"type": "number"},
          "cogs": {
            "type": "object",
            "required": ["raw_materials", "packaging", "labels", "boxes", "shipping", "customs", "total"],
            "properties": {
              "raw_materials": {"type": "number"},
              "packaging": {"type": "number"},
              "labels": {"type": "number"},
              "boxes": {"type": "number"},
              "shipping": {"type": "number"},
              "customs": {"type": "number"},
              "total": {"type": "number"}
            }
          },
          "opex": {
            "type": "object",
            "required": ["factory", "personnel", "services", "other", "total"],
            "properties": {
              "factory": {"type": "number"},
              "personnel": {"type": "number"},
              "services": {"type": "number", "minimum": 0},
              "other": {"type": "number"},
              "total": {"type": "number"}
            }
          },
          "capex": {"type": "number"},
          "otherRevenue": {"type": "number"},
          "totalRevenue": {"type": "number"},
          "opProfit": {"type": "number"},
          "opMargin": {"type": "number"},
          "founderInjection": {"type": "number"},
          "export": {"type": "number"},
          "exportShare": {"type": "number"},
          "clients": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "country", "amount", "key"],
              "properties": {
                "name": {"type": "string"},
                "country": {"type": "string"},
                "amount": {"type": "number"},
                "key": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "agKassa": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["month", "label", "in", "out", "ending", "endingSource"],
        "properties": {
          "month": {"type": "string"},
          "label": {"type": "string"},
          "in": {"type": "number"},
          "out": {"type": "number"},
          "ending": {"type": "number"},
          "endingSource": {"type": "string", "enum": ["xlsx", "computed"]},
          "note": {"type": "string"}
        }
      }
    },
    "cashPositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["account", "currency", "balance", "eurEquiv"],
        "properties": {
          "account": {"type": "string"},
          "currency": {"type": "string", "enum": ["TL", "EUR", "USD", "?"]},
          "balance": {"type": "number"},
          "eurEquiv": {"type": "number"}
        }
      }
    },
    "payroll": {"type": ["object", "null"]},
    "productShipments": {"type": ["array", "null"]},
    "inventory": {"type": ["object", "null"]},
    "capex": {"type": ["object", "null"]},
    "scenarios": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "exitValue", "probability", "rev2030", "ebitda2030"],
        "properties": {
          "name": {"type": "string"},
          "rev2030": {"type": "number"},
          "ebitda2030": {"type": "number"},
          "multiple": {"type": "number"},
          "exitValue": {"type": "number"},
          "probability": {"type": "number", "minimum": 0, "maximum": 1},
          "comparable": {"type": "string"}
        }
      }
    },
    "loreal_acquisitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "year", "multiple_rev"],
        "properties": {
          "name": {"type": "string"},
          "year": {"type": "integer"},
          "value": {"type": ["integer", "null"]},
          "rev_est": {"type": ["integer", "null"]},
          "multiple_rev": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "valuation": {
      "type": "object",
      "required": ["method", "components", "totalLow", "totalHigh", "userShare7pct"],
      "properties": {
        "method": {"type": "string"},
        "components": {"type": "array"},
        "totalLow": {"type": "integer"},
        "totalHigh": {"type": "integer"},
        "userShare7pct": {
          "type": "object",
          "required": ["low", "high"],
          "properties": {
            "low": {"type": "integer"},
            "high": {"type": "integer"}
          }
        }
      }
    }
  }
}
